# ============================================================
# VARIABLES DE ENTORNO - Backend Colegio Jose
# ============================================================

# --- Servidor ---
PORT=4000

# Zona horaria: OBLIGATORIA configurarla también en Railway → Variables del servicio.
# Toda la app (Node + Postgres por sesión) se ancla a America/Lima (UTC-5, sin DST)
# para que los registros muestren la misma fecha/hora en local y en producción.
TZ=America/Lima
# Hace que `psql` y herramientas pg muestren la TZ correcta al inspeccionar.
PGTZ=America/Lima

# --- Base de datos PostgreSQL (Railway: usar la URL que provee Railway) ---
DATABASE_URL="postgresql://user:password@localhost:5432/db_colegio_jose?schema=public"

# --- Variables legacy (solo si NO usas DATABASE_URL) ---
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=db_colegio_jose
# DB_PORT=5432

# --- Seguridad ---
JWT_SECRET=cambia-este-secreto-en-produccion

# --- Seed inicial (opcionales, solo se usan al ejecutar `npm run seed`) ---
ADMIN_EMAIL=admin@colegiojose.edu.pe
ADMIN_PASSWORD=admin123
ADMIN_NOMBRES=ADMINISTRADOR
ADMIN_APELLIDOS=SISTEMA
NOMBRE_SISTEMA=Colegio Jose
COLOR_PRIMARIO=#1976D2
COLOR_SECUNDARIO=#42A5F5
COLOR_ACENTO=#0D47A1

# ============================================================
# Almacenamiento de archivos
# ============================================================
# STORAGE_TYPE=local     (archivos locales en /uploads — solo dev)
# STORAGE_TYPE=wasabi    (S3-compatible: requiere las variables de abajo)
STORAGE_TYPE=wasabi
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.wasabisys.com
# Bucket primario donde se almacenan logos, fotos, materiales, etc.
WASABI_BUCKET=colegiojose-uploads
# Bucket secundario para artefactos internos del backend (exportes, backups...)
WASABI_BUCKET_BACKEND=colegiojose-backend
