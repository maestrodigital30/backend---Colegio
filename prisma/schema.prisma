  nivel           String? @db.VarChar(50)
  tema_visual     String  @default("clasico") @db.VarChar(30)
  publicado       Boolean @default(false)
  multimedia_url  String? @db.VarChar(500)
  multimedia_tipo String? @db.VarChar(20)

  // Configuracion de juego
  tiempo_por_pregunta      Int     @default(20)
  puntos_base              Int     @default(100)
  penalizacion_incorrecta  Int     @default(0)
  orden_preguntas          String  @default("fijo") @db.VarChar(20)
  orden_opciones           String  @default("fijo") @db.VarChar(20)
  permite_reintentos       Boolean @default(true)
  max_intentos_por_usuario Int     @default(0)

  // Comodines
  comodin_50_50_habilitado         Boolean @default(true)
  comodin_tiempo_extra_habilitado  Boolean @default(true)
  comodin_tiempo_extra_segundos    Int     @default(10)
  comodin_doble_puntaje_habilitado Boolean @default(true)

  // Ronda bonus
  bonus_habilitado        Boolean @default(false)
  bonus_cantidad_tarjetas Int     @default(5)
  bonus_premio_minimo     Int     @default(10)
  bonus_premio_maximo     Int     @default(100)

  id_usuario_registro     Int?
  fecha_hora_registro     DateTime? @default(now()) @db.Timestamptz(6)
  id_usuario_modificacion Int?
  fecha_hora_modificacion DateTime? @db.Timestamptz(6)
  estado                  Int       @default(1)

  tbl_cursos             tbl_cursos?              @relation(fields: [id_curso], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concursos_curso")
  tbl_usuarios           tbl_usuarios?            @relation(fields: [id_usuario_registro], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concursos_usuario_registro")
  tbl_concurso_preguntas tbl_concurso_preguntas[]
  tbl_concurso_intentos  tbl_concurso_intentos[]
}

model tbl_concurso_preguntas {
  id                      Int       @id @default(autoincrement())
  id_concurso             Int
  texto                   String    @db.Text
  orden                   Int       @default(1)
  puntos                  Int?
  tiempo_limite_segundos  Int?
  multimedia_url          String?   @db.VarChar(500)
  multimedia_tipo         String?   @db.VarChar(20)
  permite_multiple        Boolean   @default(false)
  id_usuario_registro     Int?
  fecha_hora_registro     DateTime? @default(now()) @db.Timestamptz(6)
  id_usuario_modificacion Int?
  fecha_hora_modificacion DateTime? @db.Timestamptz(6)
  estado                  Int       @default(1)

  tbl_concursos           tbl_concursos             @relation(fields: [id_concurso], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_preguntas_concurso")
  tbl_concurso_opciones   tbl_concurso_opciones[]
  tbl_concurso_respuestas tbl_concurso_respuestas[]
}

model tbl_concurso_opciones {
  id                      Int       @id @default(autoincrement())
  id_pregunta             Int
  texto                   String?   @db.Text
  es_correcta             Boolean   @default(false)
  orden                   Int       @default(1)
  multimedia_url          String?   @db.VarChar(500)
  multimedia_tipo         String?   @db.VarChar(20)
  id_usuario_registro     Int?
  fecha_hora_registro     DateTime? @default(now()) @db.Timestamptz(6)
  id_usuario_modificacion Int?
  fecha_hora_modificacion DateTime? @db.Timestamptz(6)
  estado                  Int       @default(1)

  tbl_concurso_preguntas  tbl_concurso_preguntas    @relation(fields: [id_pregunta], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_opciones_pregunta")
  tbl_concurso_respuestas tbl_concurso_respuestas[]
}

model tbl_concurso_intentos {
  id                          Int       @id @default(autoincrement())
  id_concurso                 Int
  id_usuario                  Int
  id_alumno                   Int?
  estado_intento              String    @default("en_progreso") @db.VarChar(20)
  puntaje_preguntas           Int       @default(0)
  puntaje_bonus               Int       @default(0)
  puntaje_total               Int       @default(0)
  respuestas_correctas        Int       @default(0)
  respuestas_incorrectas      Int       @default(0)
  preguntas_totales           Int       @default(0)
  tiempo_total_segundos       Int       @default(0)
  comodin_50_50_usado         Boolean   @default(false)
  comodin_tiempo_extra_usado  Boolean   @default(false)
  comodin_doble_puntaje_usado Boolean   @default(false)
  token_intento               String    @unique @db.VarChar(500)
  fecha_hora_inicio           DateTime  @default(now()) @db.Timestamptz(6)
  fecha_hora_fin              DateTime? @db.Timestamptz(6)
  estado                      Int       @default(1)

  tbl_concursos               tbl_concursos                 @relation(fields: [id_concurso], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_intentos_concurso")
  tbl_usuarios                tbl_usuarios                  @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_intentos_usuario")
  tbl_alumnos                 tbl_alumnos?                  @relation(fields: [id_alumno], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_intentos_alumno")
  tbl_concurso_respuestas     tbl_concurso_respuestas[]
  tbl_concurso_bonus_tarjetas tbl_concurso_bonus_tarjetas[]
}

model tbl_concurso_respuestas {
  id                             Int      @id @default(autoincrement())
  id_intento                     Int
  id_pregunta                    Int
  id_opcion_seleccionada         Int?
  ids_opciones_seleccionadas     String?  @db.Text
  es_correcta                    Boolean  @default(false)
  puntos_obtenidos               Int      @default(0)
  tiempo_usado_segundos          Int      @default(0)
  comodin_50_50_aplicado         Boolean  @default(false)
  comodin_tiempo_extra_aplicado  Boolean  @default(false)
  comodin_doble_puntaje_aplicado Boolean  @default(false)
  fecha_hora_respuesta           DateTime @default(now()) @db.Timestamptz(6)
  estado                         Int      @default(1)

  tbl_concurso_intentos  tbl_concurso_intentos  @relation(fields: [id_intento], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_respuestas_intento")
  tbl_concurso_preguntas tbl_concurso_preguntas @relation(fields: [id_pregunta], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_respuestas_pregunta")
  tbl_concurso_opciones  tbl_concurso_opciones? @relation(fields: [id_opcion_seleccionada], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_respuestas_opcion")

  @@unique([id_intento, id_pregunta], map: "uq_concurso_respuesta_intento_pregunta")
}

model tbl_concurso_bonus_tarjetas {
  id                   Int       @id @default(autoincrement())
  id_intento           Int
  orden                Int
  puntos               Int
  seleccionada         Boolean   @default(false)
  fecha_hora_seleccion DateTime? @db.Timestamptz(6)
  estado               Int       @default(1)

  tbl_concurso_intentos tbl_concurso_intentos @relation(fields: [id_intento], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_concurso_bonus_intento")
}
